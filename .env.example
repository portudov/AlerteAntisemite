# ------------------------------------------------------------------
# Configuration de la plateforme de signalements
# Copiez ce fichier en ".env" et adaptez les valeurs.
# ------------------------------------------------------------------

# Port du serveur (les hebergeurs definissent souvent PORT automatiquement)
PORT=3000

# Mot de passe administrateur INITIAL (utilise seulement a la 1ere creation
# de la base). Si vous le LAISSEZ VIDE, un mot de passe aleatoire fort sera
# genere et affiche UNE seule fois dans les logs au demarrage. Definissez-le
# ici (ou dans l'hebergeur) pour choisir le votre. Modifiable ensuite dans Parametres.
ADMIN_PASSWORD=

# Cle API Google Gemini. Vous pouvez la laisser vide ici et la coller
# directement dans la page Parametres de l'interface admin.
GEMINI_API_KEY=

# Modele Gemini par defaut (modifiable dans Parametres).
# Important : sur le niveau GRATUIT, utilisez gemini-2.5-flash
# (les modeles gemini-2.0-* ne sont plus disponibles gratuitement).
GEMINI_MODEL=gemini-2.5-flash

# Mettre "production" une fois en ligne (active les cookies securises HTTPS)
NODE_ENV=development

# Chemin du fichier de base de donnees (optionnel)
# DB_PATH=./data/app.db
